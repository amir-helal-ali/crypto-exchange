worker_processes auto;

events {
  worker_connections 1024;
}

http {
  include /etc/nginx/mime.types;
  default_type application/octet-stream;

  # resolver for docker DNS — 127.0.0.11 is the embedded Docker DNS
  resolver 127.0.0.11 valid=5s ipv6=off;

  # Gzip compression
  gzip on;
  gzip_vary on;
  gzip_min_length 1024;
  gzip_proxied any;
  gzip_comp_level 6;
  gzip_types text/plain text/css text/xml application/json application/javascript application/xml+rss application/atom+xml image/svg+xml;

  # WebSocket upgrade mapping
  map $http_upgrade $connection_upgrade {
    default upgrade;
    '' close;
  }

  # ===========================================
  # Upstream definitions
  # ===========================================
  upstream backend_upstream {
    server backend:3000;
  }
  upstream frontend_upstream {
    server frontend:3000;
  }
  upstream admin_upstream {
    server admin:3000;
  }

  # ===========================================
  # Domain routing map
  # ===========================================
  map $host $upstream {
    hostnames;
    default ${FRONTEND_UPSTREAM_URL};
    ~^${BACKEND_DOMAIN_REGEX}$  ${BACKEND_UPSTREAM_URL};
    ~^${ADMIN_DOMAIN_REGEX}$    ${ADMIN_UPSTREAM_URL};
  }

  # ===========================================
  # HTTP server (port 80)
  # ===========================================
  server {
    listen 80;
    server_name ${ALL_DOMAINS};

    # Let's Encrypt ACME challenge
    location /.well-known/acme-challenge/ {
      root /var/www/certbot;
      default_type "text/plain";
      auth_basic off;
      try_files $uri =404;
    }

    ${HTTP_BLOCK_CONTENT}
  }

  # ===========================================
  # HTTPS server (port 443) — only when SSL is enabled
  # ===========================================
  ${HTTPS_SERVER_BLOCK}
}
