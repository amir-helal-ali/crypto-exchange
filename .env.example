# ===========================================
# EgMoney Crypto Exchange - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ---- Security ----
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_PASSWORD=Admin@123456

# ---- Frontend URL (for email verification links) ----
FRONTEND_URL=https://eg-money.local

# ---- SMTP Email Configuration ----
# Required for email verification, password reset, etc.
# If not set, verification links will be printed to console logs (dev mode)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=EgMoney
SMTP_FROM_EMAIL=noreply@eg-money.com

# ---- Database ----
DATABASE_URL=host=postgres user=egmoney password=EgMoney@2024Secure! dbname=crypto_exchange port=5432 sslmode=disable

# ---- Backend ----
PORT=3000
