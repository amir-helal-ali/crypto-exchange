# ===========================================
# EgMoney Crypto Exchange - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
#
# IMPORTANT: Generate secure values for production!
#   JWT_SECRET: openssl rand -hex 32
#   ADMIN_PASSWORD: openssl rand -base64 16
#   POSTGRES_PASSWORD: openssl rand -base64 24

# ===========================================
# SECURITY (CRITICAL - Must set in production)
# ===========================================

# JWT Secret - Used for signing authentication tokens.
# MUST be at least 32 random characters. Application WILL NOT START without it.
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string-in-production

# Admin password - Password for the admin user created on first startup.
# Application WILL NOT START without it (no default for security).
# Minimum: 8 chars, 1 uppercase, 1 lowercase, 1 digit, 1 special character.
ADMIN_PASSWORD=

# ===========================================
# DATABASE (REQUIRED)
# ===========================================

# PostgreSQL connection string for the Go backend.
# Application WILL NOT START without it (no hardcoded fallback).
# When using Docker Compose, the host is the service name "postgres".
DATABASE_URL=host=postgres user=egmoney password=EgMoney@2024Secure! dbname=crypto_exchange port=5432 sslmode=disable

# PostgreSQL container settings (used by docker-compose)
POSTGRES_USER=egmoney
POSTGRES_PASSWORD=EgMoney@2024Secure!
POSTGRES_DB=crypto_exchange

# ===========================================
# SMTP EMAIL CONFIGURATION
# ===========================================

# SMTP settings for sending verification emails, password resets, etc.
# If SMTP_USER and SMTP_PASS are empty, emails will be printed to console logs (dev mode).
# For development, use Mailtrap (https://mailtrap.io) or similar.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=EgMoney
SMTP_FROM_EMAIL=noreply@eg-money.com

# ===========================================
# FRONTEND URLS
# ===========================================

# Frontend base URL - used for generating verification/reset links in emails.
FRONTEND_URL=https://eg-money.local

# API URL - used by Next.js frontend and admin to connect to the backend.
# In Docker, this should be the public-facing URL via nginx.
NEXT_PUBLIC_API_URL=https://api.eg-money.local

# ===========================================
# CORS (Optional)
# ===========================================

# Custom CORS origin - additional origin allowed for API requests.
# Useful for production deployments with different domains.
# CORS_ORIGIN=https://your-production-domain.com

# ===========================================
# BACKEND
# ===========================================

# Backend server port (inside container)
PORT=3000

# ===========================================
# REDIS
# ===========================================

# Redis URL for rate limiting and caching.
# If not set, in-memory rate limiting is used (not suitable for multi-instance).
REDIS_URL=redis://redis:6379/0

# ===========================================
# DOMAINS (used by nginx + SSL generation)
# ===========================================
MAIN_DOMAIN=localhost
FRONTEND_DOMAIN=localhost
BACKEND_DOMAIN=localhost
ADMIN_DOMAIN=localhost
SSL_ENABLED=false

# ===========================================
# PORTS (configurable from admin panel)
# ===========================================
# Nginx listen ports — applied dynamically via nginx reload
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Internal service ports — ports services listen on INSIDE Docker containers
# These are used by nginx upstream configuration
BACKEND_INTERNAL_PORT=3000
FRONTEND_INTERNAL_PORT=3000
ADMIN_INTERNAL_PORT=3000

# Host access ports — ports mapped to the host machine
# Changing these requires: docker compose up -d
BACKEND_HOST_PORT=3000
FRONTEND_HOST_PORT=3001
ADMIN_HOST_PORT=3002
